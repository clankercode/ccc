#!/bin/sh
set -eu

usage() {
  printf 'usage: ccc [runner] [+thinking] [:provider:model] [@alias] "<Prompt>"\n' >&2
}

trim() {
  printf '%s' "$1" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//'
}

read_config_value() {
  key=$1

  candidates=""
  if [ "${CCC_CONFIG:-}" != "" ]; then
    candidates="$CCC_CONFIG"
  fi
  if [ "${XDG_CONFIG_HOME:-}" != "" ]; then
    candidates="$candidates ${XDG_CONFIG_HOME}/ccc/config.toml ${XDG_CONFIG_HOME}/ccc/config"
  fi
  if [ "${HOME:-}" != "" ]; then
    candidates="$candidates ${HOME}/.config/ccc/config.toml ${HOME}/.config/ccc/config"
  fi

  for path in $candidates; do
    [ -f "$path" ] || continue
    value=$(
      awk -F= -v wanted="$key" '
        /^[[:space:]]*\[defaults\][[:space:]]*$/ { section = "defaults"; next }
        /^[[:space:]]*\[/ { section = ""; next }
        {
          line = $0
          sub(/^[[:space:]]+/, "", line)
          sub(/[[:space:]]+$/, "", line)
          if (line == "" || substr(line, 1, 1) == "#") next
          split(line, parts, "=")
          if (length(parts) < 2) next
          lhs = parts[1]
          rhs = substr(line, index(line, "=") + 1)
          sub(/^[[:space:]]+/, "", lhs)
          sub(/[[:space:]]+$/, "", lhs)
          sub(/^[[:space:]]+/, "", rhs)
          sub(/[[:space:]]+$/, "", rhs)
          gsub(/^"/, "", rhs)
          gsub(/"$/, "", rhs)
          if ((wanted == "default_runner" && lhs == "default_runner") ||
              (wanted == "runner" && section == "defaults" && lhs == "runner")) {
            print rhs
            exit
          }
        }
      ' "$path"
    )
    if [ "$value" != "" ]; then
      printf '%s' "$value"
      return 0
    fi
  done

  return 1
}

if [ "$#" -eq 0 ]; then
  usage
  exit 1
fi

if [ "$#" -eq 1 ] && { [ "$1" = "--help" ] || [ "$1" = "-h" ]; }; then
  printf 'ccc — call coding CLIs\n'
  exit 0
fi

if [ "$#" -ne 1 ]; then
  usage
  exit 1
fi

prompt=$(trim "$1")
if [ "$prompt" = "" ]; then
  printf 'prompt must not be empty\n' >&2
  exit 1
fi

runner=$(read_config_value runner || read_config_value default_runner || printf 'opencode')

case "$runner" in
  opencode|oc)
    bin=${CCC_REAL_OPENCODE:-opencode}
    if ! command -v "$bin" >/dev/null 2>&1; then
      printf 'ccc: failed to start %s\n' "$bin" >&2
      exit 127
    fi
    exec "$bin" run "$prompt"
    ;;
  claude|cc|c)
    exec claude "$prompt"
    ;;
  kimi|k)
    exec kimi "$prompt"
    ;;
  codex|rc)
    exec codex "$prompt"
    ;;
  crush|cr)
    exec crush "$prompt"
    ;;
  *)
    exec "$runner" "$prompt"
    ;;
esac
