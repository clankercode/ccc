#!/usr/bin/env perl
use strict;
use warnings;
use FindBin;
use lib "$FindBin::Bin/../lib";

use Call::Coding::Clis::Parser qw(parse_args resolve_command);
use Call::Coding::Clis::Config qw(load_config);
use Call::Coding::Clis::Runner;
use Call::Coding::Clis::CommandSpec;
use Call::Coding::Clis::Help qw(print_help print_usage);

if (!@ARGV) {
    print_usage();
    exit 1;
}

if (@ARGV == 1 && ($ARGV[0] eq '--help' || $ARGV[0] eq '-h')) {
    print_help();
    exit 0;
}

my $parsed = parse_args(@ARGV);
if (!$parsed->{prompt} || $parsed->{prompt} !~ /\S/) {
    print STDERR "prompt must not be empty\n";
    exit 1;
}

my $config = load_config();
my $cmd    = eval { resolve_command($parsed, $config) };
if ($@) {
    print STDERR $@;
    exit 1;
}

if ($cmd->{warnings} && @{$cmd->{warnings}}) {
    print STDERR "$_\n" for @{$cmd->{warnings}};
}

my @argv = @{$cmd->{argv}};
if ($ENV{CCC_REAL_OPENCODE}) {
    $argv[0] = $ENV{CCC_REAL_OPENCODE};
}

my $spec = Call::Coding::Clis::CommandSpec->new(
    argv => \@argv,
    env  => $cmd->{env},
);

my $runner = Call::Coding::Clis::Runner->new;
my $result = $runner->run($spec);

if (defined $result->stdout && length $result->stdout) {
    print $result->stdout;
}
if (defined $result->stderr && length $result->stderr) {
    print STDERR $result->stderr;
}
exit($result->exit_code);
