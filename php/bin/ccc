#!/usr/bin/env php
<?php

require_once __DIR__ . '/../src/CommandSpec.php';
require_once __DIR__ . '/../src/CompletedRun.php';
require_once __DIR__ . '/../src/Runner.php';
require_once __DIR__ . '/../src/Parser.php';
require_once __DIR__ . '/../src/Config.php';
require_once __DIR__ . '/../src/Help.php';
require_once __DIR__ . '/../src/build_prompt_spec.php';

use Call\Coding\Clis\Runner;
use Call\Coding\Clis\Parser;
use Call\Coding\Clis\Config;
use Call\Coding\Clis\CommandSpec;
use Call\Coding\Clis\Help;
use function Call\Coding\Clis\build_prompt_spec;

$args = array_slice($argv, 1);

if (count($args) === 0) {
    Help::printUsage();
    exit(1);
}

if ($args === ['--help'] || $args === ['-h']) {
    Help::printHelp();
    exit(0);
}

$config = Config::loadConfig();

try {
    $parsed = Parser::parseArgs(array_slice($argv, 1));

    if ($parsed->runner !== null || $parsed->thinking !== null
        || $parsed->provider !== null || $parsed->model !== null
        || $parsed->alias !== null
    ) {
        $resolved = Parser::resolveCommand($parsed, $config);
        $spec = new CommandSpec($resolved['argv'], null, null, $resolved['env']);
    } else {
        $spec = build_prompt_spec($argv[1]);
    }
} catch (\Throwable $e) {
    fwrite(STDERR, $e->getMessage() . "\n");
    exit(1);
}

if (($override = getenv('CCC_REAL_OPENCODE')) !== false) {
    $spec->argv[0] = $override;
}

$runner = new Runner();
$result = $runner->run($spec);

if ($result->stdout !== '') {
    fwrite(STDOUT, $result->stdout);
}
if ($result->stderr !== '') {
    fwrite(STDERR, $result->stderr);
}
exit($result->exit_code);
