#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "../lib/call_coding_clis"

args = ARGV

if args.empty?
  warn 'usage: ccc "<Prompt>"'
  exit 1
end

begin
  config = CallCodingClis::Config.load_config
  spec = CallCodingClis.build_v2_spec(args, config: config)
rescue ArgumentError => e
  warn e.message
  exit 1
end

if (real = ENV["CCC_REAL_OPENCODE"])
  spec = CallCodingClis::CommandSpec.new(
    argv: [real, *spec.argv[1..]],
    stdin_text: spec.stdin_text,
    cwd: spec.cwd,
    env: spec.env
  )
end

result = CallCodingClis::Runner.new.stream(spec) do |channel, text|
  case channel
  when "stdout"
    $stdout.write(text)
  when "stderr"
    $stderr.write(text)
  end
end

exit(result.exit_code)
