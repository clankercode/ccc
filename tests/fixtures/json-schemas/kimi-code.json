{
  "_meta": {
    "source": "Kimi Code CLI by Moonshot AI",
    "invocation": "kimi --print --output-format stream-json -p '<prompt>'",
    "format": "NDJSON (newline-delimited JSON) — each line is a serialized Pydantic model via model_dump_json(exclude_none=True)",
    "flags": {
      "print": "--print (non-interactive mode, implies --yolo)",
      "output_format": "--output-format text|stream-json",
      "input_format": "--input-format text|stream-json",
      "final_message_only": "--final-message-only",
      "quiet": "--quiet (alias for --print --output-format text --final-message-only)"
    }
  },

  "message_assistant_text": {
    "role": "assistant",
    "content": "I'll read the file for you."
  },

  "message_assistant_text_with_think": {
    "role": "assistant",
    "content": [
      {"type": "think", "think": "I need to analyze this code...", "encrypted": null},
      {"type": "text", "text": "I'll read the file for you."}
    ]
  },

  "message_assistant_with_tool_calls": {
    "role": "assistant",
    "content": [
      {"type": "text", "text": "Let me read that file."}
    ],
    "tool_calls": [
      {
        "type": "function",
        "id": "call_abc123",
        "function": {
          "name": "read_file",
          "arguments": "{\"path\":\"/src/main.py\"}"
        }
      }
    ]
  },

  "message_tool_result_success": {
    "role": "tool",
    "content": [
      {"type": "text", "text": "<system>Tool completed successfully.</system>"},
      {"type": "text", "text": "file contents here..."}
    ],
    "tool_call_id": "call_abc123"
  },

  "message_tool_result_error": {
    "role": "tool",
    "content": [
      {"type": "text", "text": "<system>ERROR: Command failed with exit code 1</system>"},
      {"type": "text", "text": "error output..."}
    ],
    "tool_call_id": "call_abc123"
  },

  "content_part_text": {
    "type": "text",
    "text": "Hello, world!"
  },

  "content_part_think": {
    "type": "think",
    "think": "I need to analyze this code...",
    "encrypted": null
  },

  "content_part_image_url": {
    "type": "image_url",
    "image_url": {"url": "https://example.com/image.png", "id": null}
  },

  "notification": {
    "id": "notif-uuid",
    "category": "status",
    "type": "info",
    "source_kind": "foreground_turn",
    "source_id": "session-id",
    "title": "Notification Title",
    "body": "Details here",
    "severity": "info",
    "created_at": 1712500000.0,
    "payload": {}
  },

  "plan_display": {
    "content": "# Plan\n\n1. Step one\n2. Step two",
    "file_path": "/path/to/plan.md"
  },

  "wire_turn_begin": {
    "type": "TurnBegin",
    "payload": {
      "user_input": "Read the file main.py"
    }
  },

  "wire_step_begin": {
    "type": "StepBegin",
    "payload": {
      "n": 1
    }
  },

  "wire_step_interrupted": {
    "type": "StepInterrupted",
    "payload": {}
  },

  "wire_turn_end": {
    "type": "TurnEnd",
    "payload": {}
  },

  "wire_status_update": {
    "type": "StatusUpdate",
    "payload": {
      "context_usage": 0.45,
      "context_tokens": 4500,
      "max_context_tokens": 10000,
      "token_usage": {
        "input_tokens": 500,
        "output_tokens": 150,
        "cache_read_tokens": 0,
        "cache_write_tokens": 0
      },
      "message_id": "msg-uuid-123",
      "plan_mode": false,
      "mcp_status": null
    }
  },

  "wire_hook_triggered": {
    "type": "HookTriggered",
    "payload": {
      "event": "PreToolUse",
      "target": "Bash",
      "hook_count": 1
    }
  },

  "wire_hook_resolved": {
    "type": "HookResolved",
    "payload": {
      "event": "PreToolUse",
      "target": "Bash",
      "action": "allow",
      "reason": "",
      "duration_ms": 50
    }
  },

  "wire_approval_request": {
    "type": "ApprovalRequest",
    "payload": {
      "id": "approval-uuid",
      "tool_call_id": "call_abc123",
      "sender": "assistant",
      "action": "execute_bash",
      "description": "Run command: ls -la",
      "display": []
    }
  },

  "wire_subagent_event": {
    "type": "SubagentEvent",
    "payload": {
      "parent_tool_call_id": "call_parent",
      "agent_id": "agent-uuid",
      "subagent_type": null,
      "event": {
        "type": "ContentPart",
        "payload": {"type": "text", "text": "Subagent output"}
      }
    }
  },

  "wire_tool_call_request": {
    "type": "ToolCallRequest",
    "payload": {
      "id": "call_abc123",
      "name": "read_file",
      "arguments": "{\"path\":\"/src/main.py\"}"
    }
  },

  "input_stream_json_user_message": {
    "role": "user",
    "content": "What does this code do?"
  }
}
